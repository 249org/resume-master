# Copy to `.dev.vars` for local `next dev` with OpenNext Cloudflare.
# Values should mirror `.env` for billing — otherwise Polar may use stale/missing tokens.

# POLAR_ACCESS_TOKEN=
# POLAR_ENV=sandbox
# POLAR_SUCCESS_URL=http://localhost:3000/success?checkout_id={CHECKOUT_ID}
# POLAR_PRODUCT_PRO_ID=
# POLAR_PRODUCT_BASIC_ID=
# POLAR_PRODUCT_FREE_ID=
