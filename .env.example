# base url
BASE_URL="http://localhost:3000"

# Cloudflare D1 database (used by drizzle-kit for remote migrations)
CLOUDFLARE_ACCOUNT_ID=Your Cloudflare account ID
CLOUDFLARE_D1_DATABASE_ID=Your D1 database ID (from: wrangler d1 create resume-master-db)
CLOUDFLARE_D1_TOKEN=Your Cloudflare API token (D1 Edit permission)

# better auth
BETTER_AUTH_SECRET= Your Better Auth secret
BETTER_AUTH_URL=Base URL of your app
GITHUB_CLIENT_ID= Your GitHub client ID
GITHUB_CLIENT_SECRET= Your GitHub client secret
GOOGLE_CLIENT_ID= Your Google OAuth client ID
GOOGLE_CLIENT_SECRET= Your Google OAuth client secret

# Polar payments — access token + POLAR_ENV must match the same Polar workspace
# (Sandbox vs Production). If POLAR_ENV is unset, the API defaults to **production**.
# Product IDs from the Sandbox dashboard only work with POLAR_ENV=sandbox.
#
# Use an Organization Access Token (Settings → Developers) — prefix polar_oat_.
# If Polar returns 401 invalid_token: wrong token type, expired/revoked token, or
# sandbox token used without POLAR_ENV=sandbox (or production token with sandbox).
# With OpenNext Cloudflare dev, mirror these vars in .dev.vars so the worker sees them.
# Org token scopes for full billing UI: customers:read, orders:read, payments:read
# (plus checkout/auth scopes your Better Auth Polar plugin requires)
POLAR_ACCESS_TOKEN=XXX
POLAR_ENV=sandbox
POLAR_SUCCESS_URL=https://example.com/success?checkout_id={CHECKOUT_ID}
# Checkout: set product UUIDs from Polar → Products (Sandbox vs Production must match POLAR_ENV).
# Without these, checkout returns "Product does not exist."
# POLAR_PRODUCT_PRO_ID=
# POLAR_PRODUCT_BASIC_ID=
# POLAR_PRODUCT_FREE_ID=
# POLAR_WEBHOOK_SECRET= (optional — enable webhooks plugin in auth.ts)

# Job Match AI report (optional: omit to get ATS report only)
OPENAI_API_KEY=Your OpenAI API key