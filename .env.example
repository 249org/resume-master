# base url
BASE_URL="http://localhost:3000"

# Cloudflare D1 database (used by drizzle-kit for remote migrations)
CLOUDFLARE_ACCOUNT_ID=Your Cloudflare account ID
CLOUDFLARE_D1_DATABASE_ID=Your D1 database ID (from: wrangler d1 create resume-master-db)
CLOUDFLARE_D1_TOKEN=Your Cloudflare API token (D1 Edit permission)

# better auth
BETTER_AUTH_SECRET= Your Better Auth secret
BETTER_AUTH_URL=Base URL of your app
GITHUB_CLIENT_ID= Your GitHub client ID
GITHUB_CLIENT_SECRET= Your GitHub client secret

# Polar payments
POLAR_ACCESS_TOKEN=XXX
POLAR_SUCCESS_URL=https://example.com/success?checkout_id={CHECKOUT_ID}

# Job Match AI report (optional: omit to get ATS report only)
OPENAI_API_KEY=Your OpenAI API key